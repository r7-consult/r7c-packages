{
  "name": "onlyoffice-ui-sdk",
  "version": "1.0.0",
  "description": "Comprehensive UI component library and SDK for OnlyOffice plugin development",
  "main": "dist/onlyoffice-ui-sdk.cjs.js",
  "module": "dist/onlyoffice-ui-sdk.esm.js",
  "browser": "dist/onlyoffice-ui-sdk.umd.js",
  "types": "types/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/",
    "src/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "NODE_ENV=production rollup -c",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/onlyoffice/ui-sdk.git"
  },
  "keywords": [
    "onlyoffice",
    "plugin",
    "ui",
    "sdk",
    "components",
    "word",
    "excel",
    "powerpoint",
    "javascript"
  ],
  "author": "OnlyOffice UI SDK Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "ie >= 11"
  ],
  "dependencies": {
    "core-js": "^3.30.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/plugin-proposal-class-properties": "^7.18.0",
    "@babel/plugin-proposal-logical-assignment-operators": "^7.20.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.0",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-proposal-private-methods": "^7.18.0",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^7.20.0",
    "@babel/plugin-transform-block-scoping": "^7.21.0",
    "@babel/plugin-transform-destructuring": "^7.21.0",
    "@babel/plugin-transform-for-of": "^7.21.0",
    "@babel/plugin-transform-parameters": "^7.21.0",
    "@babel/plugin-transform-spread": "^7.20.0",
    "@babel/preset-env": "^7.21.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^8.37.0",
    "eslint-config-standard": "^17.0.0",
    "rimraf": "^4.4.0",
    "rollup": "^3.20.0"
  },
  "eslintConfig": {
    "extends": "standard",
    "env": {
      "browser": true,
      "node": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-debugger": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  }
}
